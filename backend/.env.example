# Supabase credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# The Odds API
ODDS_API_KEY=your-odds-api-key-here
# Optional: limit player props scan markets locally to reduce quota usage.
# Example: PLAYER_PROP_MARKETS=player_points
PLAYER_PROP_MARKETS=
# Optional: require at least this many peer books in the player-props consensus
# after excluding the target book. Default is 3.
PLAYER_PROP_MIN_REFERENCE_BOOKMAKERS=3
# Optional: Pick'em board/research can use a looser paired-book threshold than
# surfaced sportsbook prop cards. Default is 2.
PLAYER_PROP_PICKEM_MIN_REFERENCE_BOOKMAKERS=2

# Environment
# Use ENVIRONMENT=development locally to limit full scans to one sport (NBA)
# and protect Odds API quota. In production, set ENVIRONMENT=production.
ENVIRONMENT=development
# Optional structured log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Ops trigger endpoints (used for manual/external scheduler triggers)
# Keep this secret and configure your trigger client to send `X-Ops-Token: <CRON_TOKEN>`.
CRON_TOKEN=your-random-cron-token-here

# Discord alerts (optional)
# Store your Discord webhook URL here to enable alerts after scan runs.
# Routing:
# - alert messages prefer DISCORD_ALERT_WEBHOOK_URL
#   (board-drop notifications for the 10:30 and 15:30 daily board runs)
# - heartbeat/test/debug messages prefer DISCORD_DEBUG_WEBHOOK_URL
# - all message types fall back to DISCORD_WEBHOOK_URL if the specialized webhook is unset
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_ALERT_WEBHOOK_URL=
DISCORD_DEBUG_WEBHOOK_URL=
# Optional: ping a role on webhook messages (enable Developer Mode in Discord to copy Role ID)
DISCORD_MENTION_ROLE_ID=
DISCORD_ALERT_MENTION_ROLE_ID=
DISCORD_DEBUG_MENTION_ROLE_ID=
# Optional ops heartbeat for scheduler/ops-trigger runs (legacy env name; set to 1 to enable).
# - Auto-settle: sends a summary after each auto-settle run
# - JIT CLV: sends a summary when close snapshots are captured
# Board drops now send alert-level notifications instead of debug heartbeats.
DISCORD_AUTO_SETTLE_HEARTBEAT=0

# CLV close capture can use a looser player-prop book threshold than surfaced cards.
PLAYER_PROP_CLV_MIN_REFERENCE_BOOKMAKERS=1

# APScheduler guard (optional)
# If you run an always-on backend and want APScheduler jobs enabled, set this to 1.
# Recommended production split:
# - API container:      APP_ROLE=api, ENABLE_SCHEDULER=1, UVICORN_WORKERS=2+
# - Scheduler container: APP_ROLE=scheduler, ENABLE_SCHEDULER=1
ENABLE_SCHEDULER=0
APP_ROLE=api
UVICORN_WORKERS=2
# Optional temporary scheduled scan time in Phoenix local time (24h HH:MM), useful for one-off autolog tests.
# Example: 14:45
SCHEDULED_SCAN_TEMP_TIME_PHOENIX=

# V1 paper autolog experiment (optional)
# Keep disabled by default; enable only after scanner duplicate-state UX is validated.
# Preferred neutral names:
ENABLE_PAPER_EXPERIMENT_AUTOLOG=0
# User ID that receives auto-logged paper entries.
PAPER_EXPERIMENT_ACCOUNT_USER_ID=

# Shared state (optional, recommended for multi-instance)
# Enables shared scan cache, scan rate limiting, and Discord alert dedupe.
REDIS_URL=redis://localhost:6379/0
# Discord alert dedupe window in seconds (default 6h)
ALERT_DEDUPE_TTL_SECONDS=21600
