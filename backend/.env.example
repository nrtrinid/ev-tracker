# Supabase credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# The Odds API
ODDS_API_KEY=your-odds-api-key-here
# Optional: limit player props scan markets locally to reduce quota usage.
# Example: PLAYER_PROP_MARKETS=player_points
PLAYER_PROP_MARKETS=
# Optional: append shadow/player-prop trial markets to the default sport registry
# without replacing the full list. Accepts:
# - 1 / true / all
# - sport keys like baseball_mlb
# - specific market keys like batter_strikeouts
PLAYER_PROP_INCLUDE_SHADOW_MARKETS=
# Optional: append alternate-line MLB markets without replacing the full list.
# Accepts:
# - 1 / true / all
# - sport keys like baseball_mlb
# - specific market keys like pitcher_strikeouts_alternate
PLAYER_PROP_INCLUDE_ALTERNATE_MARKETS=
# Optional: require at least this many peer books in the player-props consensus
# after excluding the target book. Default is 2.
PLAYER_PROP_MIN_REFERENCE_BOOKMAKERS=2

# Environment
# Use ENVIRONMENT=development locally to limit full scans to one sport (NBA)
# and protect Odds API quota. In production, set ENVIRONMENT=production.
ENVIRONMENT=development
# Optional structured log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Ops trigger endpoints (used for manual/external scheduler triggers)
# Keep this secret and configure your trigger client to send `X-Ops-Token: <CRON_TOKEN>`.
CRON_TOKEN=your-random-cron-token-here
# Optional trusted-beta invite code. Case, spaces, and punctuation are ignored,
# so simple word-of-mouth phrases like "Daily Drop" work well.
BETA_INVITE_CODE="Daily Drop"
# Internal operator access allowlist.
OPS_ADMIN_EMAILS=ops@example.com

# Discord alerts (optional)
# Store your Discord webhook URL here to enable +EV alerts after scan runs.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Optional: ping a role on webhook messages (enable Developer Mode in Discord to copy Role ID)
DISCORD_MENTION_ROLE_ID=
# Alert-path delivery is enabled by default.
# Set to 0 only when you explicitly want alert-path notifications disabled.
DISCORD_ENABLE_ALERT_ROUTE=1
# Optional dedicated alert webhook/role (preferred for user-facing board alerts).
DISCORD_ALERT_WEBHOOK_URL=
DISCORD_ALERT_MENTION_ROLE_ID=
# Optional dedicated debug/test webhook/role (recommended for ops + test traffic).
DISCORD_DEBUG_WEBHOOK_URL=
DISCORD_DEBUG_MENTION_ROLE_ID=
# Optional safety toggle: allow heartbeat/test messages to fall back to DISCORD_WEBHOOK_URL.
# Keep 0 unless you explicitly want debug/test traffic to share the primary channel.
DISCORD_ALLOW_DEBUG_FALLBACK_TO_PRIMARY=0
# Route `/api/ops/trigger/test-discord-alert` through debug/test by default
# to avoid alert-channel noise during testing.
# Set to `alert` only when you intentionally want that test endpoint to hit the alert webhook path.
DISCORD_TEST_ALERT_MESSAGE_TYPE=test
# Optional heartbeat for scheduler/ops-trigger runs (set to 1 to enable).
# - Auto-settle: sends a summary after each auto-settle run
# - Scan: sends a heartbeat only when a scan run schedules 0 alerts
DISCORD_AUTO_SETTLE_HEARTBEAT=0
# Scheduler Discord scan alert mode.
# - timed_ping (default): one board-drop ping at scheduled windows
# - edge_live: send per-edge alerts when qualifying lines are found
DISCORD_SCAN_ALERT_MODE=timed_ping

# APScheduler guard (optional)
# If you run an always-on backend and want APScheduler jobs enabled, set this to 1.
ENABLE_SCHEDULER=0
# Optional temporary scheduled scan time in Phoenix local time (24h HH:MM), useful for one-off autolog tests.
# Example: 14:45
SCHEDULED_SCAN_TEMP_TIME_PHOENIX=

# V1 paper autolog experiment (optional)
# Keep disabled by default; enable only after scanner duplicate-state UX is validated.
# Preferred neutral names:
ENABLE_PAPER_EXPERIMENT_AUTOLOG=0
# User ID that receives auto-logged paper entries.
PAPER_EXPERIMENT_ACCOUNT_USER_ID=

# Shared state (optional, recommended for multi-instance)
# Enables shared scan cache, scan rate limiting, and Discord alert dedupe.
REDIS_URL=redis://localhost:6379/0
# Discord alert dedupe window in seconds (default 6h)
ALERT_DEDUPE_TTL_SECONDS=21600
