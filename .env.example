# Copy to .env on the VPS (chmod 600). Used by docker-compose and the backend container.
# See backend/.env.example for full local-dev options (Discord, Redis, etc.).

# Hostname Caddy serves and gets HTTPS for (must match your public DNS A record).
API_DOMAIN=api.example.com

# Required for the API to start
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Production behavior (scanner full sports, etc.)
ENVIRONMENT=production

# Leave off or 0 until the web backend is stable; scheduler uses APScheduler + Odds API
ENABLE_SCHEDULER=0

# Required for user-driven scans and odds-backed routes
ODDS_API_KEY=your-odds-api-key

# Optional: ops/cron routes need this as X-Ops-Token; omit if unused
# CRON_TOKEN=

# Optional structured logging: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# First deploy: omit REDIS_URL so rate limits and scan cache stay in-process on this VPS.
# Add Redis later if you need shared state across multiple instances.
