# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Same-origin browser API path in Vercel production:
# NEXT_PUBLIC_API_URL=/api/backend
#
# Hetzner backend origin used by Next/Vercel server-side bridge routes:
# BACKEND_BASE_URL=http://5.78.192.196
# In local development, keep both values pointed at localhost.
BACKEND_BASE_URL=http://localhost:8000

# Server-side secrets for internal bridge routes (never exposed to browser)
CRON_SECRET=replace-with-random-secret
# Optional override for backend X-Ops-Token value
CRON_TOKEN=replace-with-backend-cron-token

# Internal operator access allowlist (comma-separated emails).
# Exact-match after lowercase/trim normalization. Leave empty to fail closed.
OPS_ADMIN_EMAILS=ops@example.com

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
