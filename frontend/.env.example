# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend base URL for Vercel cron bridge routes
# Example production value: https://your-backend-service.onrender.com
BACKEND_BASE_URL=http://localhost:8000

# Server-side secrets for internal bridge routes (never exposed to browser)
CRON_SECRET=dev-cron-secret
# Optional override for backend X-Ops-Token value
# A dummy value is fine for local route tests; use the backend's real CRON_TOKEN in deployed envs.
CRON_TOKEN=dev-cron-token

# Internal operator access allowlist (comma-separated emails).
# Exact-match after lowercase/trim normalization. Leave empty to fail closed.
OPS_ADMIN_EMAILS=ops@example.com
# Optional trusted-beta invite code. The frontend server uses this to validate
# signup codes before account creation. Case, spaces, and punctuation are ignored.
BETA_INVITE_CODE="Daily Drop"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public beta support link
NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.gg/your-beta-invite
